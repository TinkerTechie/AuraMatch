# ─────────────────────────────────────────────────────────────────────────────
# AuraMatch Delhi — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# On Render/Heroku, set these in the dashboard Environment Variables section.
# ─────────────────────────────────────────────────────────────────────────────

# Required — your Groq API key (get one free at console.groq.com)
GROQ_API_KEY=gsk_...

# Optional — Flask secret key (used for sessions/signing; generate a random string)
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Optional — override the SQLite DB path (default: instance/auramatch.db)
# For Render persistent disk, set to an absolute path on the mounted volume:
# DATABASE_URL=sqlite:////mnt/data/auramatch.db
